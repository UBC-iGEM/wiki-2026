---
import type { DatabaseAttrs } from "@exporter/markdown/markdown";
import { PagePath, PagePathComponent } from "@exporter/map";
import DbSidebar from "../components/DbSidebar.astro";
import MainLayout from "./MainLayout.astro";

interface Props {
    attrs: DatabaseAttrs;
}
const { attrs } = Astro.props;

type DatabaseAttrsWithPath = DatabaseAttrs & {
    current_page_path?: string;
    page_path?: string;
    path?: string;
};

const attrs_with_path = attrs as DatabaseAttrsWithPath;
const current_page_path =
    attrs_with_path.current_page_path ??
    attrs_with_path.page_path ??
    attrs_with_path.path ??
    // Current exports only expose the database path and page title, so reconstruct the full path here.
    new PagePath([
        ...PagePath.fromString(attrs.parent_db_path).components(),
        new PagePathComponent(attrs.title),
    ]).toString();
---

<MainLayout title={attrs.title}>
    <!-- <div class="db-datetime">{attrs.datetime}</div> -->
    <div class="db-layout">
        <aside class="db-sidebar">
            <DbSidebar parent_db_path={attrs.parent_db_path} current_page_path={current_page_path} />
        </aside>
        <main class="db-content">
            <slot />
        </main>
    </div>
</MainLayout>

<style>
    .db-layout {
        align-items: start;
        display: grid;
        gap: 1rem;
        grid-template-columns: minmax(12rem, 18rem) minmax(0, 1fr);
        padding: 1rem;
    }

    aside.db-sidebar {
        border: 1px solid #dddddd;
        max-height: calc(100vh - 8rem);
        overflow-y: auto;
        padding: 1rem;
        position: sticky;
        top: 1rem;
    }

    .db-content {
        min-width: 0;
    }

    @media (max-width: 700px) {
        .db-layout {
            grid-template-columns: 1fr;
        }

        aside.db-sidebar {
            max-height: 16rem;
            position: static;
        }
    }
</style>
