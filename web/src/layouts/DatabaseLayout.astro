---
import type { MarkdownHeading } from "astro";
import type { DatabaseAttrs } from "@exporter/markdown/markdown";
import { PagePath } from "@exporter/map";
import DbSidebar from "../components/DbSidebar.astro";
import MainLayout from "./MainLayout.astro";

interface Props {
    attrs: DatabaseAttrs;
    headings?: MarkdownHeading[];
}
const { attrs, headings } = Astro.props;

const current_page_path = attrs.path;
const parent_db_path = new PagePath(PagePath.fromString(attrs.path).components().slice(0, 2)).toString();
---

<MainLayout title={attrs.title} headings={headings}>
    <div class="db-layout">
        <aside class="db-sidebar">
            <DbSidebar parent_db_path={parent_db_path} current_page_path={current_page_path} />
        </aside>
        <main class="db-content">
            <slot />
        </main>
    </div>
</MainLayout>

<style>
    .db-layout {
        align-items: start;
        display: grid;
        gap: 1rem;
        grid-template-columns: minmax(12rem, 18rem) minmax(0, 1fr);
    }

    aside.db-sidebar {
        border: 1px solid #dddddd;
        max-height: calc(100vh - 8rem);
        overflow-y: auto;
        padding: 1rem;
        position: sticky;
        top: 1rem;
    }

    .db-content {
        min-width: 0;
    }

    @media (max-width: 700px) {
        .db-layout {
            grid-template-columns: 1fr;
        }

        aside.db-sidebar {
            max-height: 16rem;
            position: static;
        }
    }
</style>
