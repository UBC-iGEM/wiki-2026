---
import "katex/dist/katex.min.css";
import "../style.css";

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>Astro Page</title>
    </head>
    <body>
        <div class="page-title">{title}</div>
        <slot />
    </body>
</html>
