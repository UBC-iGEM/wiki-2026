---
import type { MarkdownHeading } from "astro";

interface Props {
    headings: MarkdownHeading[];
}
const { headings } = Astro.props;

// Indent each entry relative to the shallowest heading on the page
// For instance, if there are H2 headings but not H1 headings,
// H2 headings are the minimum depth and should be left-aligned
const min_depth = headings.reduce((min, h) => Math.min(min, h.depth), 6);
---

<nav class="toc" aria-label="Table of contents">
    <p class="toc-title">On this page</p>
    <ul>
        {
            headings.map((heading) => (
                <li style={`padding-left: ${(heading.depth - min_depth) * 0.75}rem`}>
                    <a href={`#${heading.slug}`} data-toc-slug={heading.slug}>
                        {heading.text}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<script>
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>("nav.toc a[data-toc-slug]"));

    if (links.length > 0) {
        const link_by_slug = new Map<string, HTMLAnchorElement>();
        const targets: HTMLElement[] = [];

        for (const link of links) {
            const slug = link.dataset.tocSlug!;
            const heading = document.getElementById(slug);
            if (heading) {
                link_by_slug.set(slug, link);
                targets.push(heading);
            }
        }

        const visible = new Set<string>();

        // Mark a heading as active
        const setActive = (slug: string | null) => {
            for (const [key, link] of link_by_slug) {
                link.classList.toggle("active", key === slug);
            }
        };

        // Determine which heading is active (in user view)
        const pickActive = () => {
            // Prefer the topmost heading currently in view
            let active: string | null = null;
            let best_top = Infinity;
            for (const el of targets) {
                if (!visible.has(el.id)) continue;
                const top = el.getBoundingClientRect().top;
                if (top < best_top) {
                    best_top = top;
                    active = el.id;
                }
            }

            // Nothing in view (e.g. scrolled past)
            if (!active) {
                for (const el of targets) {
                    // Highlight the last heading above
                    if (el.getBoundingClientRect().top < 100) active = el.id;
                }
            }

            setActive(active);
        };

        // Pick new active heading on scroll
        const observer = new IntersectionObserver(
            (entries) => {
                for (const entry of entries) {
                    if (entry.isIntersecting) visible.add(entry.target.id);
                    else visible.delete(entry.target.id);
                }
                pickActive();
            },
            { rootMargin: "-80px 0px -60% 0px", threshold: 0 },
        );

        targets.forEach((target) => observer.observe(target));
    }
</script>

<style>
    .toc {
        font-size: 0.85rem;
    }

    .toc-title {
        color: #666666;
        font-weight: 700;
        margin: 0 0 0.5rem;
    }

    ul {
        list-style: none;
        margin: 0;
        padding: 0;
    }

    a {
        border-left: 2px solid transparent;
        color: #555555;
        display: block;
        padding: 0.25rem 0.5rem;
        text-decoration: none;
    }

    a:hover,
    a.active {
        color: #000000;
    }

    a.active {
        border-left-color: #000000;
        font-weight: 600;
    }
</style>
