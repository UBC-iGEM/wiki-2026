---
import { type CalloutAttrs } from "@exporter/markdown/components-block";
type Props = CalloutAttrs;

const attrs = Astro.props;
---

<div class="callout">
    <span class="icon">{attrs.icon}</span>
    <div class="content">
        <slot />
    </div>
</div>

<style>
    .callout {
        display: flex;
        align-items: flex-start;
        gap: 0.75rem;
        background-color: #d3d3d3;
        padding: 20px 10px;
        border-radius: 10px;
    }

    .icon {
        flex-shrink: 0;
    }

    .content :global(> *:first-child) {
        margin-top: 0 !important;
    }
</style>
