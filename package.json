{
    "name": "wiki",
    "private": true,
    "workspaces": [
        "exporter/",
        "web/"
    ],
    "devDependencies": {
        "@trivago/prettier-plugin-sort-imports": "^6.0.2",
        "@types/node": "^25.9.1",
        "@typescript-eslint/parser": "^8.60.0",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-astro": "^1.7.0",
        "eslint-plugin-prettier": "^5.5.6",
        "exporter": "workspace:*",
        "jiti": "^2.7.0",
        "prettier": "^3.9.0",
        "prettier-plugin-astro": "^0.14.1",
        "typescript-eslint": "^8.60.0"
    },
    "scripts": {
        "export": "npx tsx --env-file=.env exporter/src/main.ts",
        "dev": "npm run dev -w web",
        "build": "npm run build -w web",
        "fmt": "prettier . --write",
        "lint": "eslint .",
        "check": "tsc --noEmit -p exporter/tsconfig.json && npm run astro check -w web",
        "validate": "npm run check && npm run lint",
        "clean": "rm -rf web/docs && rm -rf exporter/debug"
    },
    "dependencies": {
        "sharp": "^0.35.3",
        "tsx": "^4.22.3"
    },
    "allowScripts": {
        "core-js-pure@3.49.0": true,
        "esbuild@0.28.0": true,
        "esbuild@0.27.7": true,
        "sharp@0.34.5": true
    }
}
